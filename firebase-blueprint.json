{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "coupleId": { "type": "string", "description": "ID of the couple this user belongs to" },
        "individualIncome": { "type": "number", "description": "Individual monthly income" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Couple": {
      "title": "Couple",
      "description": "Couple group information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "jointIncome": { "type": "number", "description": "Combined monthly income" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "members"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction (income or expense)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "coupleId": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["pix", "dinheiro", "cartao"] },
        "cardName": { "type": "string", "description": "Name of the card if paymentMethod is cartao" },
        "dueDate": { "type": "string", "format": "date" },
        "paid": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["id", "coupleId", "description", "amount", "type", "category", "paymentMethod", "paid"]
    },
    "Goal": {
      "title": "Goal",
      "description": "Financial goal for the couple",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "coupleId": { "type": "string" },
        "title": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "coupleId", "title", "targetAmount", "currentAmount"]
    },
    "LearningProgress": {
      "title": "LearningProgress",
      "description": "Progress in the financial learning trail",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "completedSteps": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId", "completedSteps"]
    },
    "MonthlyBill": {
      "title": "MonthlyBill",
      "description": "A recurring monthly bill",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "coupleId": { "type": "string" },
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "dueDateDay": { "type": "integer", "minimum": 1, "maximum": 31 },
        "category": { "type": "string" },
        "paid": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "coupleId", "title", "amount", "dueDateDay", "category", "paid"]
    },
    "Loan": {
      "title": "Loan",
      "description": "Information about a loan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "coupleId": { "type": "string" },
        "title": { "type": "string" },
        "totalAmount": { "type": "number" },
        "remainingAmount": { "type": "number" },
        "interestRate": { "type": "number" },
        "monthlyPayment": { "type": "number" },
        "dueDateDay": { "type": "integer", "minimum": 1, "maximum": 31 },
        "totalInstallments": { "type": "integer", "minimum": 1 },
        "currentInstallment": { "type": "integer", "minimum": 0 },
        "lender": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "coupleId", "title", "totalAmount", "remainingAmount", "interestRate", "monthlyPayment", "dueDateDay"]
    },
    "Investment": {
      "title": "Investment",
      "description": "Information about an investment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "coupleId": { "type": "string" },
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string" },
        "interestRate": { "type": "number" },
        "totalInstallments": { "type": "integer" },
        "currentInstallment": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "coupleId", "title", "amount", "type"]
    },
    "WalletAccount": {
      "title": "WalletAccount",
      "description": "Bank account or piggy bank",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "coupleId": { "type": "string" },
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "isPiggyBank": { "type": "boolean" },
        "lender": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "coupleId", "name", "balance", "isPiggyBank"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/couples/{coupleId}": {
      "schema": "Couple",
      "description": "Couple groups"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "All transactions"
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "Financial goals"
    },
    "/monthlyBills/{billId}": {
      "schema": "MonthlyBill",
      "description": "Recurring monthly bills"
    },
    "/loans/{loanId}": {
      "schema": "Loan",
      "description": "Active loans"
    },
    "/investments/{investmentId}": {
      "schema": "Investment",
      "description": "Current investments"
    },
    "/wallets/{walletId}": {
      "schema": "WalletAccount",
      "description": "Bank accounts and savings"
    },
    "/learningProgress/{userId}": {
      "schema": "LearningProgress",
      "description": "User learning trail progress"
    }
  }
}
